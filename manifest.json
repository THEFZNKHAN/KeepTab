{
  "manifest_version": 3,
  "name": "KeepTab",
  "version": "2.0.0",
  "description": "Save tabs, links, and notes to a personal board. One-click capture, clipboard export, optional Google Keep sync. Private and local.",
  "permissions": ["storage", "tabs", "scripting", "debugger"],
  "host_permissions": [
    "https://keep.google.com/*"
  ],
  "action": {
    "default_popup": "dist/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
